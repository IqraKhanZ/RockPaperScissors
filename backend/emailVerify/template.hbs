<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Email Verification</title>
</head>
<body style="margin:0;padding:0;font-family:'Segoe UI',sans-serif;background:#f4f4f4;">
	<div style="max-width:600px;margin:24px auto;background:#fff;padding:24px;border-radius:8px;">
		<h2 style="margin:0 0 16px;color:#222;">Verify Your Email Address</h2>
		<p style="color:#555;line-height:1.6;">
			Thank you for registering. Please verify your email address by clicking the button below.
		</p>
		<p style="margin:24px 0;">
			<a href="{{verifyUrl}}" target="_blank" style="display:inline-block;padding:10px 18px;background:#00a63d;color:#fff;text-decoration:none;border-radius:6px;font-weight:600;">Verify Email</a>
		</p>
		<p style="color:#777;line-height:1.6;">If you did not initiate this request, you can ignore this email.</p>
	</div>
</body>
</html>
